monitor=eDP-1,1920x1080@60,0x0,1


###################
### MY PROGRAMS ###
###################
$fastfetch = fastfetch
$lock = hyprlock
$terminal = kitty
$fileManager = dolphin
$menu = wofi --show drun
$browser = firefox &
$studium = studium
$discord = discord
$spotify = spotify
$screenshot = grimblast copy area
$horaire = horaire

